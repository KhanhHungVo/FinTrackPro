{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "DatabaseProvider": {
    "Provider": "postgresql"
  },
  "ConnectionStrings": {
    // Use PostgreSQL for development by default
    "DefaultConnection": "Host=localhost;Port=5432;Database=FinTrackPro;Username=postgres;Password=YourStrong@Passw0rd;" ,
    //"DefaultConnection": "Server=localhost,1433;Database=FinTrackPro;User Id=sa;Password=YourStrong@Passw0rd;TrustServerCertificate=true;",
    "_DefaultConnection_hint_sqlserver": "SQL Server: Server=tcp:<server>.database.windows.net,1433;Initial Catalog=FinTrackPro;User ID=<admin>;Password=<secret>;Encrypt=True;",
    "_DefaultConnection_hint_postgresql": "PostgreSQL: Host=<host>;Port=5432;Database=FinTrackPro;Username=<user>;Password=<secret>;SSL Mode=Require;"
  },
  "IdentityProvider": {
    "Provider": "keycloak",
    "Audience": "https://api.fintrackpro.dev",
    "AdminClientId": "fintrackpro-api",
    "AdminClientSecret": ""
  },
  "Keycloak": {
    "Authority": "http://localhost:8080/realms/fintrackpro",
    "MetadataAddress": "http://localhost:8080/realms/fintrackpro/.well-known/openid-configuration"
  },
  "Auth0": {
    "Domain": ""
  },
  "Telegram": {
    "BotToken": "0000000000:AAEhBOweik_placeholder_replace_me_xx"
  },
  "CoinGecko": {
    "ApiKey": ""
  },
  "ExternalApis": {
    "BinanceBaseUrl": "https://api.binance.com",
    "FearGreedBaseUrl": "https://api.alternative.me",
    "CoinGeckoBaseUrl": "https://api.coingecko.com"
  },
  "Cors": {
    "Origins": "http://localhost:5173"
  },
  "Hangfire": {
    "Username": "hangfire-admin",
    "Password": ""
  },
  "HttpLogging": {
    "MaskSensitiveData": true
  },
  "HttpResilience": {
    "RetryCount": 3,
    "RetryBaseDelayMs": 500,
    "TimeoutSeconds": 30,
    "CircuitBreakerFailurePercent": 50,
    "CircuitBreakerBreakDurationSeconds": 30,
    "CircuitBreakerSamplingDurationSeconds": 60,
    "CircuitBreakerMinimumThroughput": 5
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    }
  }
}
