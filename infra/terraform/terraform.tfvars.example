# terraform.tfvars.example — copy to terraform.tfvars and fill in real values.
# terraform.tfvars is gitignored — never commit it.
#
# Alternatively, set all variables as Terraform Cloud workspace variables
# (recommended) and skip creating a local terraform.tfvars entirely.

# ── Render ─────────────────────────────────────────────────────────────────────
render_owner_id = "usr-xxxxxxxxxx"   # Render dashboard → Account → ID

# ── Auth0 ──────────────────────────────────────────────────────────────────────
auth0_domain         = "dev-xxxx.us.auth0.com"
auth0_m2m_client_id  = "your-m2m-client-id"

# ── App ────────────────────────────────────────────────────────────────────────
# Retrieve from the Render dashboard → your PostgreSQL instance → Connections → External Connection String.
# Use Npgsql key-value format (not a libpq URI):
# db_connection_string = "Host=dpg-xxxx-a.singapore-postgres.render.com;Port=5432;Database=fintrackpro_db_xxxx;Username=fintrackpro_db_xxxx_user;Password=xxxx;SSL Mode=Require;"
# Treat this as sensitive — set it as a Terraform Cloud workspace variable (sensitive) rather than storing it here.

# Set cors_origins to the frontend URL after first deploy.
# Re-run `terraform apply` once you have the URL.
cors_origins = "https://fintrackpro-ui.onrender.com"

# ── Frontend (VITE_*) ──────────────────────────────────────────────────────────
# Set vite_api_base_url to the API URL after first deploy.
vite_api_base_url    = "https://fintrackpro-api.onrender.com"
vite_auth0_domain    = "dev-xxxx.us.auth0.com"
vite_auth0_client_id = "your-spa-client-id"

# ── Frontend bank transfer / admin contact ─────────────────────────────────────
# Public-safe values — same as printing on an invoice.
vite_admin_telegram       = "your_telegram_handle"
vite_admin_email          = "admin@fintrackpro.dev"
vite_bank_name            = "Techcombank"
vite_bank_account_number  = "your_account_number"
vite_bank_account_name    = "Your Full Name"
# vite_bank_transfer_amount defaults to "99000" — override here only if different.
# vite_bank_transfer_amount = "99000"
vite_bank_qr_url          = "https://i.postimg.cc/your-image-url.jpg"

# Sensitive variables (render_api_key, auth0_m2m_client_secret, db_connection_string,
# coingecko_api_key, exchangerate_api_key, telegram_bot_token, hangfire_dashboard_password,
# stripe_secret_key, stripe_webhook_secret)
# should be set as sensitive Terraform Cloud workspace variables,
# NOT stored here.
