    {
      "name": "Authorization Guards",
      "description": "Uses bearerToken2 (second user — User role only) to verify ownership guards reject cross-user mutations.",
      "item": [
        {
          "name": "Refresh bearerToken (user 1) → POST Keycloak /token → 200",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password",          "type": "text" },
                { "key": "client_id",  "value": "fintrackpro-e2e",   "type": "text" },
                { "key": "username",   "value": "{{testUsername}}",  "type": "text" },
                { "key": "password",   "value": "{{testPassword}}",  "type": "text" }
              ]
            },
            "url": "{{keycloakUrl}}/realms/fintrackpro/protocol/openid-connect/token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Keycloak returns 200 (user 1 token refresh)', () => {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "});",
                  "",
                  "const body = pm.response.json();",
                  "if (!body.access_token) {",
                  "    throw new Error('User1 token refresh failed: ' + JSON.stringify(body));",
                  "}",
                  "pm.environment.set('bearerToken', body.access_token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Mint bearerToken2 (user 2) → POST Keycloak /token → 200",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password",           "type": "text" },
                { "key": "client_id",  "value": "fintrackpro-e2e",    "type": "text" },
                { "key": "username",   "value": "{{testUsername2}}",  "type": "text" },
                { "key": "password",   "value": "{{testPassword2}}",  "type": "text" }
              ]
            },
            "url": "{{keycloakUrl}}/realms/fintrackpro/protocol/openid-connect/token"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Keycloak returns 200 (user 2 token mint)', () => {",
                  "    pm.response.to.have.status(200);",
                  "    const body = pm.response.json();",
                  "    pm.expect(body).to.have.property('access_token');",
                  "});",
                  "",
