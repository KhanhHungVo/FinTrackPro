              }
            }
          ]
        },
        {
          "name": "DELETE /api/transactions/{{transactionId}} → 204",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/transactions/{{transactionId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "DELETE /api/budgets/{{budgetId}} → 204",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/budgets/{{budgetId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
