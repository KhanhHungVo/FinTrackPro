                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"symbol\": \"ETHUSDT\",\n  \"direction\": \"Long\",\n  \"entryPrice\": 3000.0,\n  \"exitPrice\": 3100.0,\n  \"positionSize\": 1.0,\n  \"fees\": 2.0,\n  \"currency\": \"USD\"\n}"
