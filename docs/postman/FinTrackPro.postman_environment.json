{
  "id": "fintrackpro-env",
  "name": "FinTrackPro Local",
  "values": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5018",
      "type": "default",
      "enabled": true
    },
    {
      "key": "bearerToken",
      "value": "",
      "type": "secret",
      "enabled": true,
      "description": "JWT access token from Keycloak or Auth0. Get one from the browser devtools after login, or generate via auth provider token endpoint."
    },
    {
      "key": "budgetId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Populated automatically by the Create Budget request"
    },
    {
      "key": "transactionId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Populated automatically by the Create Transaction request"
    },
    {
      "key": "tradeId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Populated automatically by the Create Trade request"
    },
    {
      "key": "watchedSymbolId",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Populated automatically by the Add Watched Symbol request"
    }
  ],
  "_postman_variable_scope": "environment"
}
