{
  "info": {
    "name": "FinTrackPro API",
    "description": "End-to-end API test collection for FinTrackPro. Run against a locally running API (`http://localhost:5018`) with a valid JWT in the `bearerToken` environment variable.\n\n**Setup:**\n1. Start the API: `dotnet run --project backend/src/FinTrackPro.API`\n2. Import `FinTrackPro.postman_environment.json` into Postman\n3. Set `bearerToken` to a valid JWT (copy from browser devtools after login)\n4. Run the collection — IDs are captured automatically between requests\n\n**CI automation:**\n```bash\nnewman run FinTrackPro.postman_collection.json \\\n  -e FinTrackPro.postman_environment.json \\\n  --env-var \"baseUrl=http://localhost:5018\" \\\n  --env-var \"bearerToken=<jwt>\"\n```",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{bearerToken}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Unauthenticated request returns 401",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "url": "{{baseUrl}}/api/transactions"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Returns 401 when no token provided', () => {",
                  "  pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Budgets",
      "item": [
        {
          "name": "Create Budget",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/budgets",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Food\",\n  \"limitAmount\": 500.00,\n  \"month\": \"2026-03\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns a GUID', () => {",
                  "  const id = pm.response.text().replace(/\"/g, '');",
                  "  pm.expect(id).to.match(/^[0-9a-f-]{36}$/i);",
                  "  pm.environment.set('budgetId', id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Budgets",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/api/budgets/2026-03"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns array', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body).to.be.an('array');",
                  "  pm.expect(body.length).to.be.greaterThan(0);",
                  "});",
                  "pm.test('Budget has expected fields', () => {",
                  "  const budget = pm.response.json()[0];",
                  "  pm.expect(budget).to.have.property('id');",
                  "  pm.expect(budget).to.have.property('category');",
                  "  pm.expect(budget).to.have.property('limitAmount');",
                  "  pm.expect(budget).to.have.property('month');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "Update Budget",
          "request": {
            "method": "PATCH",
            "url": "{{baseUrl}}/api/budgets/{{budgetId}}",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"limitAmount\": 750.00\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        },
        {
          "name": "Create Budget - Validation error (zero amount)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/api/budgets",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"category\": \"Food\",\n  \"limitAmount\": 0,\n  \"month\": \"2026-03\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 for zero limit', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Budget",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/budgets/{{budgetId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 204', () => pm.response.to.have.status(204));"
                ]
              }
            }
          ]
        }
      ]
    },
