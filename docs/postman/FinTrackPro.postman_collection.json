              "raw": "{\n  \"type\": \"Expense\",\n  \"amount\": 50,\n  \"category\": \"\",\n  \"budgetMonth\": \"2026-03\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 for missing category', () => pm.response.to.have.status(400));"
                ]
              }
            }
          ]
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/api/transactions/{{transactionId}}"
          },
          "event": [
            {
              "listen": "test",
              "script": {
