VITE_API_BASE_URL=http://localhost:5018

# Active IAM provider: "keycloak" (default) | "auth0"
VITE_AUTH_PROVIDER=keycloak

# Keycloak (used when VITE_AUTH_PROVIDER=keycloak)
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=fintrackpro
VITE_KEYCLOAK_CLIENT_ID=fintrackpro-spa

# Auth0 (used when VITE_AUTH_PROVIDER=auth0)
VITE_AUTH0_DOMAIN=your-tenant.auth0.com
VITE_AUTH0_CLIENT_ID=your-spa-client-id
VITE_AUTH0_AUDIENCE=https://api.fintrackpro.dev

# Admin contact — shown in bank transfer modal
VITE_ADMIN_TELEGRAM=your_telegram_handle
VITE_ADMIN_EMAIL=admin@fintrackpro.dev

# Bank transfer details — replace with your actual Techcombank account
# These are public-safe values (same as printing on an invoice)
VITE_BANK_NAME=Techcombank
VITE_BANK_ACCOUNT_NUMBER=your_account_number
VITE_BANK_ACCOUNT_NAME=Your Full Name
VITE_BANK_TRANSFER_AMOUNT=99000
# Direct image URL for the bank transfer QR code (hosted externally, never committed)
VITE_BANK_QR_URL=

# Pricing tier limits — shown on the public landing page (defaults match hard-coded values)
VITE_FREE_TRANSACTIONS_LIMIT=50
VITE_FREE_HISTORY_DAYS=60
VITE_FREE_BUDGETS_LIMIT=3
VITE_FREE_TRADES_LIMIT=20
VITE_FREE_WATCHLIST_LIMIT=1
VITE_PRO_TRANSACTIONS_LIMIT=500
VITE_PRO_BUDGETS_LIMIT=20
VITE_PRO_TRADES_LIMIT=200
VITE_PRO_WATCHLIST_LIMIT=20
